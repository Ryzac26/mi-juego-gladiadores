<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gladiadores Idle</title>
    <!-- Cargamos el script de Telegram -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #1a1a1a;
            color: white;
            text-align: center;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 400px;
            margin: 0 auto;
            background: #2a2a2a;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }
        .gladiador-box {
            border: 2px solid #ff9f43;
            padding: 15px;
            margin: 15px 0;
            border-radius: 10px;
            background: #333;
        }
        .premium {
            border-color: #00d2d3;
            background: #222f3e;
        }
        button {
            background-color: #ff9f43;
            color: black;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            width: 100%;
        }
        button:hover { background-color: #ffb167; }
        .gold-display {
            font-size: 24px;
            color: #feca57;
            font-weight: bold;
            margin: 10px 0;
        }
        .tag {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 12px;
            font-weight: bold;
        }
        .tag-free { background: #576574; color: white; }
        .tag-premium { background: #10ac84; color: white; }
    </style>
</head>
<body>

    <div class="container">
        <h2>⚔️ Arena de Gladiadores ⚔️</h2>
        <p id="welcome-msg">Cargando guerrero...</p>

        <div class="gold-display">💰 Oro: <span id="gold-count">0</span></div>

        <!-- Gladiador FREE -->
        <div class="gladiador-box">
            <span class="tag tag-free">FREE</span>
            <h3>Espartaco</h3>
            <p>Genera: 1 moneda/seg</p>
            <button onclick="trainGladiator('free')">Entrenar (+1 Nivel)</button>
        </div>

        <!-- Gladiador PREMIUM -->
        <div class="gladiador-box premium">
            <span class="tag tag-premium">PREMIUM</span>
            <h3>Crixo el Magnífico</h3>
            <p>Genera: 5 monedas/seg</p>
            <button onclick="buyPremium()" style="background-color: #10ac84; color: white;">Desbloquear (⭐ Stars)</button>
        </div>
    </div>

    <script>
        // Inicializar Telegram WebApp
        const tele = window.Telegram.WebApp;
        tele.ready(); // Avisa a Telegram que la app está lista
        tele.expand(); // Abre la app a pantalla completa

        // Mostrar nombre del usuario de Telegram
        const username = tele.initDataUnsafe.user ? tele.initDataUnsafe.user.first_name : "Gladiador";
        document.getElementById('welcome-msg').innerText = `¡Bienvenido, ${username}!`;

        // Lógica del Juego (Idle)
        let gold = 0;
        let goldPerSecond = 1; // Empezamos con el gladiador free

        // Función que suma oro automáticamente cada segundo
        setInterval(() => {
            gold += goldPerSecond;
            document.getElementById('gold-count').innerText = gold;
        }, 1000);

        function trainGladiator(type) {
            goldPerSecond += 1;
            alert("¡Tu gladiador ha mejorado! Ahora genera más oro.");
        }

        function buyPremium() {
            // Aquí irá la pasarela de pago de Telegram
            alert("Pronto podrás comprar este Gladiador con Telegram Stars.");
        }
    </script>
</body>
</html>
